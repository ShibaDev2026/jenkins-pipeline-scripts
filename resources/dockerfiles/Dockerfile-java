ARG RUNTIME_VERSION=17
FROM eclipse-temurin:${RUNTIME_VERSION}-jre-alpine

ARG APP_NAME
ARG APP_VERSION
ARG BRANCH
ARG BUILD_NUMBER
ARG GIT_TAG_NAME
ARG JAR_FILE

LABEL maintainer="shiba-dev" \
      app.name="${APP_NAME}" \
      app.version="${APP_VERSION}" \
      app.branch="${BRANCH}" \
      app.build="${BUILD_NUMBER}" \
      app.tag="${GIT_TAG_NAME}"

WORKDIR /app

COPY ${JAR_FILE} app.jar

ENV APP_NAME=${APP_NAME} \
    APP_VERSION=${APP_VERSION} \
    BRANCH=${BRANCH} \
    TZ=Asia/Taipei

EXPOSE 8080

ENTRYPOINT ["java", "-jar", "app.jar"]
